{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "df-azureproject-KM"
		},
		"azls_azure_sql_km_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'azls_azure_sql_km'"
		},
		"azls_datalake_km_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'azls_datalake_km'"
		},
		"azls_azure_sql_km_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "az-sqldb-server-azproject-spotify-km.database.windows.net"
		},
		"azls_azure_sql_km_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sqldb-azproject-spotify-km"
		},
		"azls_azure_sql_km_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "Admin-KM"
		},
		"azls_datalake_km_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://storageazureprojectkm.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "df-azureproject-KM_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"azls_azure_sql_km_password": {
						"value": "[parameters('azls_azure_sql_km_password')]"
					},
					"azls_datalake_km_accountKey": {
						"value": "[parameters('azls_datalake_km_accountKey')]"
					},
					"azls_azure_sql_km_properties_typeProperties_server": {
						"value": "[parameters('azls_azure_sql_km_properties_typeProperties_server')]"
					},
					"azls_azure_sql_km_properties_typeProperties_database": {
						"value": "[parameters('azls_azure_sql_km_properties_typeProperties_database')]"
					},
					"azls_azure_sql_km_properties_typeProperties_userName": {
						"value": "[parameters('azls_azure_sql_km_properties_typeProperties_userName')]"
					},
					"azls_datalake_km_properties_typeProperties_url": {
						"value": "[parameters('azls_datalake_km_properties_typeProperties_url')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}